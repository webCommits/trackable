# Generiere einen sicheren Key mit:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Produktion: immer False
DEBUG=False

# Domain-Konfiguration (nur für docker-compose.standalone.yaml mit Traefik)
# Bei Coolify kann dies ignoriert werden, da Coolify das Routing automatisch verwaltet
SUBDOMAIN=trackable
DOMAIN_NAME=your-domain.com

# Komma-getrennte Liste aller erlaubten Domains (kein Wildcard in Produktion!)
ALLOWED_HOSTS=trackable.your-domain.com

DATABASE_URL=sqlite:///data/db.sqlite3

EMAIL_HOST=smtp.ionos.de
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@domain.com
EMAIL_HOST_PASSWORD=your-password
DEFAULT_FROM_EMAIL=noreply@trackable.your-domain.com

BACKUP_SCHEDULE=weekly
BACKUP_FILENAME=db_backup.sqlite3
MONTHLY_EMAIL_TIME=23:59
